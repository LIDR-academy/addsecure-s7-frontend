{
  "name": "lti-talent-tracking",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint": "npm run lint --prefix frontend && npm run lint --prefix backend",
    "lint:fix": "npm run lint:fix --prefix frontend && npm run lint:fix --prefix backend"
  },
  "dependencies": {
    "dotenv": "^17.2.1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "bash -c 'cd frontend && npx eslint --fix \"${0#frontend/}\"'"
    ],
    "backend/**/*.ts": [
      "bash -c 'cd backend && npx eslint --fix \"${0#backend/}\"'"
    ]
  }
}
